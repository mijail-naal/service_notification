# ===== PostgreSQL =====
POSTGRES_HOST='auth_db'
POSTGRES_USER='app'
POSTGRES_PASSWORD='123qwe'
POSTGRES_DB='movies_database'
POSTGRES_PORT=5432

# ===== Docker compose variales =====
POSTGRES_VERSION=14-alpine
REDIS_VERSION=7.2.4
REDIS_PORT=6379
