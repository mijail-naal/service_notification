# This is a .env.sample file.
# Duplicate this file as .env or rename it
# and set the environment variables to match your
# desired config.

# ===== FastAPI =====
PROJECT_NAME='Notification API'
AUTHJWT_KEY='secret'
ECHO_VAR=True
DEBUG=True
SECRET_KEY='secret'

# ===== Redis =====
REDIS_HOST='auth_redis'
REDIS_PORT=6379

# ===== PostgreSQL =====
POSTGRES_DB='notif_db'
POSTGRES_USER='fast'
POSTGRES_PASSWORD='123qwe'
POSTGRES_HOST='localhost'
POSTGRES_PORT=5432

# ===== RabbitMQ =====
RABBIT_HOST='rabbitmq'
RABBIT_PORT=5672
RABBIT_USER='guest'
RABBIT_PASSWORD='guest'
RABBIT_DELIVERY_MODE=2
RABBIT_EXCHANGE='emails'

# ===== Mongo =====
MONGO_HOST='mongodb'
MONGO_PORT=27017

# ===== Docker compose variales =====
POSTGRES_VERSION=14-alpine
REDIS_VERSION=7.2.4
REDIS_PORT=6379
RABBITMQ_VERSION=3.13.1-management
RABBITMQ_PORTS='15672:15672'
